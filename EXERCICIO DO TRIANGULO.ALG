Algoritmo "Triangulo"
//  
//  
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 27/12/2024
Var
// Seçăo de Declaraçőes das variáveis 
A, B, C: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
          escreval("Digite um valor: ")
          leia(A)
          escreval("Digite o segundo valor: ")
          leia(B)
          escreval("Digite o segundo valor: ")
          leia(C)
          se (A=B) e (B=C) entao
          escreval("Triangulo Equiloatero")
          senao
          se (A<>B) e (B<>C) e (A<>C) entao
          escreval("Triangulo Escaleno")
          senao
          escreval(" Triangulo isocele")
          fimse
          fimse

          

Fimalgoritmo